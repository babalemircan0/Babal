@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Babal | Elite Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Montserrat:wght@900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-green: #2ecc71;
            --bg-light: #f4f7f6;
            --text-dark: #1e272e;
            --card-shadow: 0 10px 30px rgba(0,0,0,0.04);
        }

        body {
            background-color: var(--bg-light);
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            min-height: 250vh; /* Orijinal yüksekliği koruduk */
            position: relative;
            overflow-x: hidden;
        }

        /* --- NAVİGASYON --- */
        nav {
            background: white;
            height: 85px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 8%;
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .logo {
            font-family: 'Montserrat', sans-serif;
            font-weight: 900;
            font-size: 28px;
            letter-spacing: -1.5px;
            color: var(--text-dark);
            text-decoration: none; /* Link stilini temizledik */
        }

            .logo span {
                color: var(--primary-green);
            }

        .nav-links {
            display: flex;
            align-items: center;
        }

            .nav-links button {
                background: none;
                border: none;
                margin-left: 25px;
                font-family: 'Inter', sans-serif;
                font-weight: 700;
                color: #8395a7;
                cursor: pointer;
                transition: 0.3s;
                font-size: 13px;
                text-transform: uppercase;
            }

                .nav-links button:hover {
                    color: var(--primary-green);
                }

        /* Ayarlar Dropdown */
        .settings-btn {
            border: 1px solid #dcdde1 !important;
            padding: 10px 20px;
            border-radius: 8px;
            margin-left: 25px;
        }

        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            right: 0;
            background-color: white;
            min-width: 220px;
            box-shadow: 0px 15px 40px rgba(0,0,0,0.1);
            border-top: 4px solid var(--primary-green);
            z-index: 1001;
            margin-top: 8px;
            border-radius: 0 0 8px 8px;
        }

            .dropdown-content a {
                color: var(--text-dark);
                padding: 14px 20px;
                text-decoration: none;
                display: block;
                font-size: 13px;
                font-weight: 700;
            }

                .dropdown-content a:hover {
                    background: #f8f9fa;
                    color: var(--primary-green);
                    padding-left: 28px;
                    transition: 0.2s;
                }

        .dropdown:hover .dropdown-content {
            display: block;
        }

        /* --- DİNAMİK KAYAN BABAL MÜHÜRÜ --- */
        #main-watermark {
            position: fixed;
            top: 45%;
            left: 50%;
            transform: translate(-50%, -50%) scale(1);
            font-family: 'Montserrat', sans-serif;
            font-size: 180px;
            font-weight: 900;
            color: #1b6615;
            opacity: 0.01;
            pointer-events: none;
            z-index: 0;
            letter-spacing: -8px;
            white-space: nowrap;
            will-change: transform, opacity, color, top;
        }

        /* --- BENTO GRID İÇERİK --- */
        .container {
            padding: 40px 8%;
            max-width: 1300px;
            margin: auto;
            position: relative;
            z-index: 2;
        }

        .greeting-section {
            margin-bottom: 40px;
        }

            .greeting-section h1 {
                font-size: 48px;
                font-weight: 800;
                margin: 0;
                letter-spacing: -2px;
            }

            .greeting-section p {
                color: var(--primary-green);
                font-weight: 700;
                margin-top: 8px;
                font-size: 14px;
                letter-spacing: 1px;
            }

        .dashboard-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 25px;
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 35px;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(0,0,0,0.02);
            position: relative;
        }

        .card-title {
            font-size: 12px;
            font-weight: 800;
            color: #bdc3c7;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 25px;
            display: block;
        }

        .focus-text {
            font-size: 28px;
            font-weight: 800;
            margin: 20px 0;
            letter-spacing: -1px;
        }

        .btn-action {
            background: var(--primary-green);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 12px;
            cursor: pointer;
            transition: 0.3s;
        }

            .btn-action:hover {
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(46, 204, 113, 0.3);
            }

        /* Haftalık Grafik Modülü */
        .chart-bars {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            height: 160px;
            margin-top: 30px;
        }

        .bar-group {
            width: 12%;
            text-align: center;
        }

        .bar {
            width: 100%;
            background: #f1f3f5;
            border-radius: 8px;
            transition: 0.6s ease;
            cursor: pointer;
        }

            .bar:hover {
                background: var(--primary-green);
            }

        .bar-label {
            font-size: 11px;
            font-weight: 800;
            color: #bdc3c7;
            margin-top: 15px;
            display: block;
        }

        /* Yan Panel Öğeleri */
        .side-item {
            padding: 18px;
            background: #fafbfc;
            border-radius: 12px;
            margin-bottom: 12px;
            font-size: 14px;
            font-weight: 700;
            transition: 0.3s;
            cursor: pointer;
            border: 1px solid transparent;
            color: var(--text-dark);
            text-decoration: none;
            display: block;
        }

            .side-item:hover {
                background: white;
                border-color: #eee;
                transform: translateX(5px);
                color: var(--primary-green);
            }

        /* --- FOOTER --- */
        footer {
            width: 100%;
            padding: 120px 0 60px 0;
            text-align: center;
            position: absolute;
            bottom: 0;
            z-index: 2;
        }

        .copyright {
            font-size: 11px;
            font-weight: 800;
            color: #bdc3c7;
            letter-spacing: 5px;
        }
    </style>
</head>
<body>

    <div id="main-watermark">BABAL</div>

    <nav>
        <a href="/Home/Index" class="logo">BABAL<span>●</span></a>
        <div class="nav-links">
            <button style="color: var(--text-dark)" onclick="location.href='/Home/Index'">ANA SAYFA</button>
            <button onclick="location.href='/Gunluk/Index'">GÜNLÜK</button>
            <button onclick="location.href='/Agenda/Index'">AJANDA</button>
            <div class="dropdown">
                <button class="settings-btn">AYARLAR ⚙️</button>
                <div class="dropdown-content">
                    <a href="#">👤 PROFİLİM</a>
                    <a href="#">🛠️ HESAP AYARLARI</a>
                    <a href="/Account/Logout" style="color: #e74c3c;">🚪 GÜVENLİ ÇIKIŞ</a>
                </div>
            </div>
        </div>
    </nav>

    <div class="container">
        <section class="greeting-section">
            <h1 id="greeting">...</h1>
            <p id="current-date">...</p>
        </section>

        <div class="dashboard-layout">
            <div class="main-column">
                <div class="card" style="border-left: 10px solid var(--primary-green);">
                    <span class="card-title">Günün Ana Odağı</span>
                    <div class="focus-text">Babal v1.0 Tasarım Revizyonu.</div>
                    <button class="btn-action">GÖREVİ TAMAMLA</button>
                </div>

                <div class="card" style="margin-top: 25px;">
                    <span class="card-title">Haftalık Verimlilik Analizi</span>
                    <div class="chart-bars">
                        <div class="bar-group"><div class="bar" style="height: 45%;"></div><span class="bar-label">PZT</span></div>
                        <div class="bar-group"><div class="bar" style="height: 75%;"></div><span class="bar-label">SAL</span></div>
                        <div class="bar-group"><div class="bar" style="height: 95%; background: var(--primary-green);"></div><span class="bar-label">ÇAR</span></div>
                        <div class="bar-group"><div class="bar" style="height: 60%;"></div><span class="bar-label">PER</span></div>
                        <div class="bar-group"><div class="bar" style="height: 40%;"></div><span class="bar-label">CUM</span></div>
                    </div>
                </div>
            </div>

            <div class="side-column">
                <div class="card">
                    <span class="card-title">Hızlı Erişim</span>
                    <div class="side-item">👤 PROFİLİM</div>
                    <div class="side-item">📊 İSTATİSTİKLER</div>
                    <div class="side-item">🔔 BİLDİRİMLER</div>
                    <a href="/Account/Logout" class="side-item" style="color: #e74c3c; text-decoration: none;">🚪 ÇIKIŞ YAP</a>
                </div>
            </div>
        </div>
    </div>

    <footer>
        <div class="copyright">© 2026 BABAL DIGITAL SYSTEMS ● TÜM HAKLARI SAKLIDIR</div>
    </footer>

    <script>
        window.onscroll = function() {
            const watermark = document.getElementById('main-watermark');
            const scrollPos = window.scrollY;
            const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
            const scrollPercent = Math.min(scrollPos / maxScroll, 1);

            const moveY = 45 + (scrollPercent * 46);
            const scale = 1 + (scrollPercent * 0.3);
            const opacity = 0.01 + (scrollPercent * 0.44);

            const startR = 223, startG = 230, startB = 233;
            const endR = 0, endG = 0, endB = 0;

            const currentR = Math.round(startR + (endR - startR) * scrollPercent);
            const currentG = Math.round(startG + (endG - startG) * scrollPercent);
            const currentB = Math.round(startB + (endB - startB) * scrollPercent);

            watermark.style.top = moveY + "%";
            watermark.style.transform = `translate(-50%, -50%) scale(${scale})`;
            watermark.style.opacity = opacity;
            watermark.style.color = `rgb(${currentR}, ${currentG}, ${currentB})`;
        };

        const hours = new Date().getHours();
        const greet = hours < 12 ? "Günaydın" : hours < 18 ? "Selam" : "İyi Akşamlar";

        // C# SESSION BURAYA ENTEGRE EDİLDİ
        const userName = "@(Context.Session.GetString("UserName") ?? "Babal")";
        document.getElementById('greeting').innerText = `${greet}, ${userName}`;

        const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };
        document.getElementById('current-date').innerText = new Date().toLocaleDateString('tr-TR', options).toUpperCase();
    </script>
</body>
</html>